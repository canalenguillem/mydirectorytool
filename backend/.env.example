GOOGLE_API_KEY=
OPENAI_API_KEY=
WP_URL=https://yoursite.com
WP_USER=
WP_APP_PASS=
DATA_DIR=/data
CORS_ORIGINS=http://localhost:8091
# Pausa entre peticiones de detalles al buscar comercios (segundos)
GOOGLE_DETAILS_DELAY_SECONDS=0.25
AUTH_USERNAME=enguillem
AUTH_PASSWORD=change-this-password
# Genera uno con: openssl rand -hex 32
AUTH_SECRET=change-this-random-secret
AUTH_SESSION_SECONDS=43200
# Usa true cuando la web se sirva exclusivamente mediante HTTPS
AUTH_COOKIE_SECURE=false
